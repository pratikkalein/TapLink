<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NFC QUICK CONTROLS"
            android:textColor="#D0BCFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/widget_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:text="● HCE ACTIVE"
            android:textColor="#4CAF50"
            android:textSize="9sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Active Spotlight Card -->
    <LinearLayout
        android:id="@+id/widget_active_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_active_card_bg"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/widget_active_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CURRENT BROADCAST ACTIVE"
            android:textColor="#D0BCFF"
            android:textSize="8sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/widget_active_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Google AI Studio"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_active_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="https://ai.studio/build"
            android:textColor="#D0BCFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Alternative profiles list header -->
    <TextView
        android:id="@+id/widget_list_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TAP TO QUICK SWITCH PROFILE"
        android:textColor="#E6E1E5"
        android:textSize="9sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="6dp" />

    <!-- Stored Profile Item 1 -->
    <LinearLayout
        android:id="@+id/widget_item_container_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_profile_item_bg"
        android:orientation="horizontal"
        android:padding="8dp"
        android:layout_marginBottom="5dp"
        android:gravity="center_vertical"
        android:focusable="true"
        android:clickable="true">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginRight="8dp">

            <TextView
                android:id="@+id/widget_item_title_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Business Card"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_item_url_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="https://li.me/in/johndoe"
                android:textColor="#E6E1E5"
                android:textColorHint="#94A3B8"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_item_action_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#381E72"
            android:text="ACTIVATE"
            android:textColor="#D0BCFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp" />
    </LinearLayout>

    <!-- Stored Profile Item 2 -->
    <LinearLayout
        android:id="@+id/widget_item_container_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_profile_item_bg"
        android:orientation="horizontal"
        android:padding="8dp"
        android:layout_marginBottom="5dp"
        android:gravity="center_vertical"
        android:focusable="true"
        android:clickable="true">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginRight="8dp">

            <TextView
                android:id="@+id/widget_item_title_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Portfolio Link"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_item_url_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="https://behance.net/jdoe"
                android:textColor="#E6E1E5"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_item_action_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#381E72"
            android:text="ACTIVATE"
            android:textColor="#D0BCFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp" />
    </LinearLayout>

    <!-- Stored Profile Item 3 -->
    <LinearLayout
        android:id="@+id/widget_item_container_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_profile_item_bg"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:focusable="true"
        android:clickable="true">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginRight="8dp">

            <TextView
                android:id="@+id/widget_item_title_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Twitter profile"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_item_url_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="https://x.com/jdoe"
                android:textColor="#E6E1E5"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_item_action_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#381E72"
            android:text="ACTIVATE"
            android:textColor="#D0BCFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp" />
    </LinearLayout>

</LinearLayout>
